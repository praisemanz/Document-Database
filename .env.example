# Database connection string for PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA

# Local PostgreSQL example:
DATABASE_URL="postgresql://postgres:password@localhost:5432/document_statement_db?schema=public"

# Replace with your actual database credentials:
# - postgres: your database username
# - password: your database password
# - localhost: your database host (use localhost for local development)
# - 5432: PostgreSQL default port
# - document_statement_db: your database name
